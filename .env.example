# ============================================================
# SOC Automation Lab — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# WAZUH
# ------------------------------------------------------------
# Mot de passe admin pour Wazuh Indexer (OpenSearch)
INDEXER_PASSWORD=ChangeMe_Indexer123!

# Credentials API Wazuh (utilisés par le Dashboard)
API_USERNAME=wazuh-wui
API_PASSWORD=ChangeMe_WazuhAPI123!

# Mot de passe service kibanaserver (dashboard interne)
DASHBOARD_PASSWORD=ChangeMe_Dashboard123!

# ------------------------------------------------------------
# THEHIVE
# ------------------------------------------------------------
# Clé secrète pour TheHive (32+ caractères recommandés)
THEHIVE_SECRET=ChangeMe_GenerateARandomSecretHere_MinLength32

# ------------------------------------------------------------
# SHUFFLE
# ------------------------------------------------------------
# Mot de passe admin OpenSearch pour Shuffle
SHUFFLE_OPENSEARCH_PASSWORD=ChangeMe_Shuffle123!

# Ports exposition frontend Shuffle
FRONTEND_PORT=3001
FRONTEND_PORT_HTTPS=3443

# Hostname du backend Shuffle (ne pas modifier sauf si conflit réseau)
BACKEND_HOSTNAME=shuffle-backend
OUTER_HOSTNAME=shuffle-backend
BACKEND_PORT=5001

# Chemins données Shuffle (volumes Docker)
SHUFFLE_APP_HOTLOAD_LOCATION=/tmp/shuffle-apps
SHUFFLE_FILE_LOCATION=/tmp/shuffle-files
DB_LOCATION=/tmp/shuffle-database

# Proxies (laisser vide si non utilisé)
HTTP_PROXY=
HTTPS_PROXY=
SHUFFLE_PASS_WORKER_PROXY=false
SHUFFLE_PASS_APP_PROXY=false

# ------------------------------------------------------------
# OSSEC / Wazuh Manager — Intégration Shuffle
# Récupérer l'IP WSL2 avec : ip addr show eth0 | grep 'inet ' | awk '{print $2}' | cut -d/ -f1
# ------------------------------------------------------------
SHUFFLE_HOST_IP=172.28.93.74
SHUFFLE_WEBHOOK_GENERAL=webhook_f3ed574e-6a42-458d-8a57-d128a9555183
SHUFFLE_WEBHOOK_VIRUSTOTAL=webhook_43e60b41-074a-49b5-ad70-9f55df6594ac
