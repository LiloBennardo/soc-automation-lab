<group name="local,syslog,">

  <rule id="100001" level="12">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(encodedcommand|frombase64|iex|invoke-expression|downloadstring|bypass|hidden|noprofile)</field>
    <description>PowerShell suspect - Commande obfusquée ou téléchargement détecté</description>
    <mitre><id>T1059.001</id></mitre>
    <group>powershell,attack,</group>
  </rule>

  <rule id="100002" level="10" frequency="5" timeframe="10">
    <if_matched_sid>5760</if_matched_sid>
    <description>Brute force SSH - 5 échecs authentification en 10 secondes</description>
    <mitre><id>T1110.001</id></mitre>
    <group>authentication_failures,attack,</group>
  </rule>

  <rule id="100003" level="8">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(nmap|masscan|zmap|portscan)</field>
    <description>Scan réseau détecté - Outil de reconnaissance potentiel</description>
    <mitre><id>T1046</id></mitre>
    <group>network_scan,attack,</group>
  </rule>

  <rule id="100004" level="12">
    <if_sid>60106</if_sid>
    <description>Création de compte utilisateur local - Persistance potentielle</description>
    <mitre><id>T1136.001</id></mitre>
    <group>account_creation,attack,</group>
  </rule>

  <rule id="100005" level="15">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(Set-MpPreference|DisableRealtimeMonitoring|DisableAntiSpyware|DisableAntiVirus)</field>
    <description>Tentative de désactivation Windows Defender - Indicateur critique</description>
    <mitre><id>T1562.001</id></mitre>
    <group>antivirus_disabled,attack,</group>
  </rule>

  <rule id="100006" level="15">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(mimikatz|sekurlsa|lsadump|procdump.*lsass|rundll32.*comsvcs)</field>
    <description>Tentative de dump credentials - Mimikatz ou outil similaire détecté</description>
    <mitre><id>T1003.001</id></mitre>
    <group>credential_dumping,attack,</group>
  </rule>

  <rule id="100007" level="10">
    <if_group>windows</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)(\\temp\\|\\appdata\\|\\public\\|\\downloads\\).*\.(exe|bat|ps1|vbs|js)</field>
    <description>Exécution depuis répertoire suspect - Masquerading potentiel</description>
    <mitre><id>T1036.005</id></mitre>
    <group>masquerading,attack,</group>
  </rule>

  <rule id="100008" level="10">
    <if_group>windows</if_group>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)(\\CurrentVersion\\Run|\\CurrentVersion\\RunOnce)</field>
    <description>Modification clé registre Run - Persistance potentielle au démarrage</description>
    <mitre><id>T1547.001</id></mitre>
    <group>registry_persistence,attack,</group>
  </rule>

  <rule id="100009" level="12">
    <if_sid>184665</if_sid>
    <field name="win.system.eventID">^1$</field>
    <description>Sysmon - Nouveau processus avec Hash détecté : $(win.eventdata.image)</description>
    <mitre><id>T1059</id></mitre>
    <group>sysmon_event1,sysmon_process_creation,</group>
  </rule>

  <rule id="100010" level="7">
    <if_sid>184665</if_sid>
    <field name="win.system.eventID">^3$</field>
    <description>Sysmon - Connexion réseau: $(win.eventdata.image) -> $(win.eventdata.destinationIp)</description>
    <mitre><id>T1071</id></mitre>
    <group>sysmon_event3,sysmon_network,</group>
  </rule>

  <rule id="100011" level="5">
    <if_sid>184665</if_sid>
    <field name="win.system.eventID">^11$</field>
    <description>Sysmon - Fichier créé: $(win.eventdata.targetFilename)</description>
    <mitre><id>T1105</id></mitre>
    <group>sysmon_event11,sysmon_file,</group>
  </rule>

</group>
